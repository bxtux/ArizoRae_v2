# ============================================================
#  ArizoRAE V2 — Configuration du stack Docker
#  Copier en .env et compléter les valeurs
# ============================================================

# ── DuckDNS ─────────────────────────────────────────────────
DUCKDNS_SUBDOMAIN=arizorae
DUCKDNS_TOKEN=REPLACE_ME
DOMAIN=arizorae.duckdns.org
PUBLIC_URL=https://${DOMAIN}

# ── Let's Encrypt ───────────────────────────────────────────
ACME_EMAIL=admin@example.com

# ── Fuseau horaire ──────────────────────────────────────────
TZ=Europe/Brussels

# ── Authentification ────────────────────────────────────────
# Clé qui signe cookies NextAuth et chiffre les clés Anthropic des users
# Générer : openssl rand -hex 32
AUTH_SECRET_KEY=REPLACE_ME

# ── Database ────────────────────────────────────────────────
POSTGRES_USER=arizorae
POSTGRES_PASSWORD=REPLACE_ME
POSTGRES_DB=arizorae
DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@postgres:5432/${POSTGRES_DB}

# ── Redis (broker Celery + cache Next) ──────────────────────
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# ── SMTP ────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=admin@example.com
SMTP_PASS=REPLACE_ME
SMTP_FROM=admin@example.com
SMTP_FROM_NAME=ArizoRAE

# ── Anthropic ───────────────────────────────────────────────
# Clé admin utilisée pour le quota gratuit de tous les users
ANTHROPIC_API_KEY_ADMIN=sk-ant-REPLACE_ME
# Quota en tokens par user (input + output) sous clé admin
DEFAULT_USER_QUOTA_TOKENS=500000

# ── Communication interne portal ↔ agent-worker ─────────────
# Secret partagé, header X-Agent-Secret. Générer : openssl rand -hex 32
AGENT_WORKER_SECRET=REPLACE_ME
AGENT_WORKER_URL=http://agent:8000

# ── Terminal ttyd ───────────────────────────────────────────
# Hash bcrypt requis par Caddy basic_auth — NE PAS mettre le mot de passe en clair ici.
# Générer : docker run --rm caddy:2-alpine caddy hash-password --plaintext VOTRE_MDP
TERMINAL_PASSWORD_HASH=REPLACE_ME_WITH_BCRYPT_HASH

# ── Gotify (notif admin) ────────────────────────────────────
GOTIFY_ADMIN_TOKEN=REPLACE_ME
GOTIFY_URL=http://gotify:80

# ── ngrok (optionnel, profil ngrok) ─────────────────────────
NGROK_AUTHTOKEN=

# ── Divers ──────────────────────────────────────────────────
NODE_ENV=production
LOG_LEVEL=info
