{
	email {$ACME_EMAIL}
	acme_dns duckdns {$DUCKDNS_TOKEN}
}

{$DOMAIN} {
	encode zstd gzip

	# Terminal ttyd (basic auth)
	handle_path /terminal/* {
		basic_auth {
			admin {$TERMINAL_PASSWORD_HASH}
		}
		reverse_proxy terminal:7681
	}

	# Gotify — redirect bare /gotify to /gotify/, then strip prefix
	redir /gotify /gotify/ 301
	handle_path /gotify/* {
		reverse_proxy gotify:80
	}

	# Portal (catchall)
	handle {
		reverse_proxy portal:3000
	}

	log {
		output stdout
		format json
	}
}

# Accès local à Gotify sans TLS (développement / admin)
# handle_path strips /gotify prefix; catch-all routes SPA's absolute API calls to Gotify too
http://localhost, http://127.0.0.1 {
	redir /gotify /gotify/ 301
	handle_path /gotify/* {
		reverse_proxy gotify:80
	}
	handle {
		reverse_proxy gotify:80
	}
}
